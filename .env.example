# Base de datos PostgreSQL de misBeneficios
DATABASE_URL=postgresql://misbeneficios:misbeneficios@localhost:5432/misbeneficios

# Opción alternativa: API REST del backend (si se prefiere no conectar directo a BD)
# API_BASE_URL=http://localhost:3001/api
# API_KEY=your-secret-key-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/scraping.log

# Scraping behavior
DRY_RUN=false
HEADLESS=true
REQUEST_DELAY_MIN=1.0
REQUEST_DELAY_MAX=3.0
REQUEST_TIMEOUT=30
MAX_RETRIES=3
